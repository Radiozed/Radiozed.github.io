---
import { getCollection } from 'astro:content';
import NekoLayout from '../../layouts/NekoLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<NekoLayout title={`${post.data.title} - Radiozed`}>
  <article class="post-page">
    <div class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <span class="post-date">{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
        {post.data.tags && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
    <div class="post-content">
      <Content />
    </div>
    <a href="/" class="back-link">← 返回首页</a>
  </article>
</NekoLayout>

<style>
  .post-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 120px 20px 80px;
  }

  .post-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .post-title {
    font-size: 2.8rem;
    background: linear-gradient(135deg, var(--text-light), var(--primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 20px;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
  }

  .post-date {
    color: var(--secondary);
    font-size: 1rem;
  }

  .post-tags {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 6px 18px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.2), rgba(255, 105, 180, 0.2));
    border: 1px solid rgba(255, 105, 180, 0.4);
    border-radius: 30px;
    font-size: 0.85rem;
    color: var(--accent);
  }

  .post-content {
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 30px;
    padding: 50px;
    backdrop-filter: blur(15px);
  }

  .post-content :global(h1) {
    font-size: 2rem;
    color: var(--text-light);
    margin-bottom: 20px;
    border-bottom: 2px solid var(--primary);
    padding-bottom: 10px;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    color: var(--primary);
    margin: 30px 0 15px;
  }

  .post-content :global(p) {
    color: var(--text-muted);
    line-height: 2;
    margin-bottom: 15px;
  }

  .post-content :global(ul), .post-content :global(ol) {
    color: var(--text-muted);
    margin: 15px 0 15px 30px;
    line-height: 2;
  }

  .post-content :global(li) {
    margin-bottom: 8px;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--glass-border);
    margin: 30px 0;
  }

  .post-content :global(em) {
    color: var(--accent);
    font-style: italic;
  }

  .post-content :global(strong) {
    color: var(--primary);
  }

  .back-link {
    display: inline-block;
    margin-top: 40px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .back-link:hover {
    color: var(--primary);
    transform: translateX(-5px);
  }

  @media (max-width: 768px) {
    .post-page {
      padding: 100px 15px 60px;
    }

    .post-title {
      font-size: 2rem;
    }

    .post-content {
      padding: 30px 20px;
    }
  }
</style>
