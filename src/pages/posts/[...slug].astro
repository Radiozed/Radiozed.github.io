---
import { getCollection } from 'astro:content';
import NekoLayout from '../../layouts/NekoLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<NekoLayout title={`${post.data.title} - Radiozed`}>
  <!-- 侧边时间日期 -->
  <div class="side-decor">
    <div class="side-date">
      <div class="date-year">{post.data.pubDate.getFullYear()}</div>
      <div class="date-day">{post.data.pubDate.getDate()}</div>
      <div class="date-month">{post.data.pubDate.toLocaleDateString('zh-CN', { month: 'short' })}</div>
    </div>
    <div class="side-decoration">
      <span class="deco-line"></span>
      <span class="deco-icon">✦</span>
      <span class="deco-line"></span>
    </div>
  </div>

  <article class="post-page">
    <div class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <span class="post-date">📅 {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        {post.data.tags && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
    <div class="post-content">
      <Content />
    </div>
    <a href="/" class="back-link">← 返回首页</a>
  </article>
</NekoLayout>

<script is:inline>
  // 代码块复制功能 - 内联脚本确保执行
  (function() {
    var preBlocks = document.querySelectorAll('pre.astro-code');
    console.log('Found code blocks:', preBlocks.length);

    preBlocks.forEach(function(pre) {
      // 创建包装器
      var wrapper = document.createElement('div');
      wrapper.className = 'code-wrapper';
      wrapper.style.cssText = 'position:relative !important;display:block;';
      pre.parentNode.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      // 创建复制按钮
      var copyBtn = document.createElement('button');
      copyBtn.className = 'copy-btn';
      copyBtn.textContent = '📋 复制';
      copyBtn.style.cssText = 'position:absolute;top:8px;right:8px;padding:6px 12px;background:rgba(255,20,147,0.8)!important;border:2px solid rgba(255,105,180,0.8);border-radius:8px;color:#fff!important;font-size:12px;cursor:pointer;z-index:99999;display:flex;align-items:center;gap:4px;';

      copyBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var codeEl = pre.querySelector('code');
        var code = codeEl ? codeEl.textContent : pre.textContent;
        navigator.clipboard.writeText(code).then(function() {
          copyBtn.textContent = '✅ 已复制!';
          copyBtn.classList.add('copied');
          setTimeout(function() {
            copyBtn.textContent = '📋 复制';
            copyBtn.classList.remove('copied');
          }, 2000);
        }).catch(function() {
          copyBtn.textContent = '❌ 失败';
        });
      });

      wrapper.appendChild(copyBtn);
    });
  })();
</script>

<style>
  .post-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 120px 20px 80px;
  }

  .post-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .post-title {
    font-size: 2.8rem;
    background: linear-gradient(135deg, var(--text-light), var(--primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 20px;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
  }

  .post-date {
    color: var(--secondary);
    font-size: 1rem;
  }

  .post-tags {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 6px 18px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.2), rgba(255, 105, 180, 0.2));
    border: 1px solid rgba(255, 105, 180, 0.4);
    border-radius: 30px;
    font-size: 0.85rem;
    color: var(--accent);
  }

  .post-content {
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 30px;
    padding: 50px;
    backdrop-filter: blur(15px);
  }

  /* 代码块样式 */
  .post-content :global(pre) {
    background: linear-gradient(135deg, rgba(20, 15, 35, 0.95), rgba(30, 20, 50, 0.9));
    border: 1px solid rgba(255, 105, 180, 0.3);
    border-radius: 16px;
    padding: 20px;
    overflow-x: auto;
    position: relative;
    margin: 20px 0;
  }

  .post-content :global(code) {
    font-family: 'Fira Code', 'Consolas', monospace;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #e0d4f7;
  }

  :global(.code-wrapper) {
    position: relative !important;
    display: block;
  }

  :global(.code-wrapper pre) {
    overflow: visible !important;
  }

  :global(.copy-btn) {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 6px 12px;
    background: rgba(255, 20, 147, 0.4) !important;
    border: 2px solid rgba(255, 105, 180, 0.6);
    border-radius: 8px;
    color: #fff !important;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 9999 !important;
    display: flex !important;
    align-items: center;
    gap: 4px;
  }

  :global(.copy-btn:hover) {
    background: rgba(255, 20, 147, 0.7) !important;
    transform: scale(1.1);
  }

  :global(.copy-btn.copied) {
    background: rgba(72, 187, 120, 0.3);
    border-color: rgba(72, 187, 120, 0.5);
    color: #68D391;
  }

  .post-content :global(h1) {
    font-size: 2rem;
    color: var(--text-light);
    margin-bottom: 20px;
    border-bottom: 2px solid var(--primary);
    padding-bottom: 10px;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    color: var(--primary);
    margin: 30px 0 15px;
  }

  .post-content :global(p) {
    color: var(--text-muted);
    line-height: 2;
    margin-bottom: 15px;
  }

  .post-content :global(ul), .post-content :global(ol) {
    color: var(--text-muted);
    margin: 15px 0 15px 30px;
    line-height: 2;
  }

  .post-content :global(li) {
    margin-bottom: 8px;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--glass-border);
    margin: 30px 0;
  }

  .post-content :global(em) {
    color: var(--accent);
    font-style: italic;
  }

  .post-content :global(strong) {
    color: var(--primary);
  }

  .back-link {
    display: inline-block;
    margin-top: 40px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .back-link:hover {
    color: var(--primary);
    transform: translateX(-5px);
  }

  /* 侧边装饰 */
  .side-decor {
    position: fixed;
    left: 30px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    z-index: 100;
  }

  .side-date {
    background: rgba(20, 15, 35, 0.8);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 105, 180, 0.2);
    border-radius: 16px;
    padding: 15px 20px;
    text-align: center;
  }

  .date-year {
    font-size: 0.8rem;
    color: var(--secondary);
    font-weight: 500;
  }

  .date-day {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-light);
    line-height: 1.2;
  }

  .date-month {
    font-size: 0.8rem;
    color: var(--accent);
  }

  .side-decoration {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0.6;
  }

  .deco-line {
    width: 2px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--primary), transparent);
  }

  .deco-icon {
    color: var(--primary);
    font-size: 1rem;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  @media (max-width: 768px) {
    .post-page {
      padding: 100px 15px 60px;
    }

    .post-title {
      font-size: 2rem;
    }

    .post-content {
      padding: 30px 20px;
    }

    .side-decor {
      display: none;
    }
  }
</style>