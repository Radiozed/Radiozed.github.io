---
import { getCollection } from 'astro:content';
import NekoLayout from '../../layouts/NekoLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<NekoLayout title={`${post.data.title} - Radiozed`}>
  <article class="post-container">
    <!-- 侧边栏 -->
    <aside class="post-sidebar">
      <!-- 日历组件 -->
      <div class="sidebar-calendar">
        <div class="calendar-header">
          <button class="calendar-nav-btn" id="prev-month-btn">‹</button>
          <span class="calendar-title" id="calendar-title">2024年1月</span>
          <button class="calendar-nav-btn" id="next-month-btn">›</button>
        </div>
        <div class="calendar-weekdays">
          <span>日</span><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span>
        </div>
        <div class="calendar-days" id="calendar-days"></div>
      </div>

      <!-- 目录导航 -->
      <nav class="sidebar-toc">
        <div class="toc-header">📑 目录</div>
        <div class="toc-list">
          <a href="#准备工作" class="toc-item">准备工作</a>
          <a href="#代码详解" class="toc-item">代码详解</a>
          <a href="#完整代码" class="toc-item">完整代码</a>
          <a href="#使用说明" class="toc-item">使用说明</a>
        </div>
      </nav>

      <!-- 文章信息 -->
      <div class="sidebar-info">
        <div class="info-item">
          <span class="info-icon">📝</span>
          <span class="info-text">{post.data.title.length}字</span>
        </div>
        <div class="info-item">
          <span class="info-icon">📅</span>
          <span class="info-text">{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
        </div>
      </div>
    </aside>

    <!-- 主内容区 -->
    <main class="post-content-area">
      <header class="post-header">
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <span class="post-date">📅 {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          {post.data.tags && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <div class="post-body">
        <Content />
      </div>

      <footer class="post-footer">
        <a href="/" class="back-button">← 返回首页</a>
      </footer>
    </main>
  </article>
</NekoLayout>

<script is:inline>
  // 平滑滚动到锚点
  document.querySelectorAll('.toc-item').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var targetId = this.getAttribute('href').substring(1);
      var target = document.getElementById(targetId);
      if (!target) {
        var allElements = document.querySelectorAll('[id*="' + targetId + '"], [id*="' + decodeURIComponent(targetId) + '"]');
        if (allElements.length > 0) {
          target = allElements[0];
        }
      }
      if (target) {
        var offset = 100;
        var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
        window.scrollTo({ top: top, behavior: 'smooth' });
      }
    });
  });

  // 代码块复制功能
  (function() {
    var preBlocks = document.querySelectorAll('pre.astro-code');

    preBlocks.forEach(function(pre) {
      // 创建包装器
      var wrapper = document.createElement('div');
      wrapper.className = 'code-wrapper';
      pre.parentNode.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      // 创建复制按钮
      var copyBtn = document.createElement('button');
      copyBtn.className = 'copy-btn';
      copyBtn.textContent = '📋 复制';

      copyBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var codeEl = pre.querySelector('code');
        var code = codeEl ? codeEl.textContent : pre.textContent;
        navigator.clipboard.writeText(code).then(function() {
          copyBtn.textContent = '✅ 已复制!';
          copyBtn.classList.add('copied');
          setTimeout(function() {
            copyBtn.textContent = '📋 复制';
            copyBtn.classList.remove('copied');
          }, 2000);
        }).catch(function() {
          copyBtn.textContent = '❌ 失败';
        });
      });

      wrapper.appendChild(copyBtn);
    });
  })();

  // 侧边栏日历
  (function() {
    let currentDate = new Date();
    const today = new Date();

    function generateCalendar(year, month) {
      const titleEl = document.getElementById('calendar-title');
      const daysEl = document.getElementById('calendar-days');
      
      if (!titleEl || !daysEl) return;
      
      titleEl.textContent = `${year}年${month + 1}月`;
      daysEl.innerHTML = '';

      const firstDay = new Date(year, month, 1);
      const lastDay = new Date(year, month + 1, 0);
      const startDay = firstDay.getDay();
      const totalDays = lastDay.getDate();

      for (let i = 0; i < startDay; i++) {
        const empty = document.createElement('span');
        empty.className = 'cal-empty';
        daysEl.appendChild(empty);
      }

      for (let d = 1; d <= totalDays; d++) {
        const day = document.createElement('span');
        day.className = 'cal-day';
        day.textContent = d;
        if (today.getFullYear() === year && today.getMonth() === month && today.getDate() === d) {
          day.classList.add('cal-today');
        }
        daysEl.appendChild(day);
      }
    }

    function prevMonth() {
      currentDate.setMonth(currentDate.getMonth() - 1);
      generateCalendar(currentDate.getFullYear(), currentDate.getMonth());
    }

    function nextMonth() {
      currentDate.setMonth(currentDate.getMonth() + 1);
      generateCalendar(currentDate.getFullYear(), currentDate.getMonth());
    }

    generateCalendar(currentDate.getFullYear(), currentDate.getMonth());
    
    document.getElementById('prev-month-btn')?.addEventListener('click', prevMonth);
    document.getElementById('next-month-btn')?.addEventListener('click', nextMonth);
  })();
</script>

<style>
  .post-container {
    display: flex;
    gap: 40px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 80px 20px;
  }

  /* 侧边栏 */
  .post-sidebar {
    width: 280px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* 侧边栏日历 */
  .sidebar-calendar {
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.85), rgba(20, 15, 35, 0.9));
    border: 1px solid rgba(255, 105, 180, 0.25);
    border-radius: 24px;
    padding: 22px;
    backdrop-filter: blur(20px);
    box-shadow: 
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    position: relative;
    overflow: hidden;
  }

  .sidebar-calendar::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
    position: relative;
    z-index: 1;
  }

  .calendar-nav-btn {
    width: 40px;
    height: 40px;
    border: none;
    background: linear-gradient(135deg, rgba(255, 105, 180, 0.2), rgba(168, 85, 247, 0.2));
    color: var(--accent);
    font-size: 1.3rem;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 105, 180, 0.2);
  }

  .calendar-nav-btn:hover {
    background: linear-gradient(135deg, rgba(255, 105, 180, 0.4), rgba(168, 85, 247, 0.4));
    transform: scale(1.15);
    box-shadow: 0 4px 15px rgba(255, 105, 180, 0.3);
  }

  .calendar-title {
    font-size: 1.1rem;
    color: var(--text-light);
    font-weight: 600;
    letter-spacing: 2px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    margin-bottom: 10px;
  }

  .calendar-weekdays span {
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-muted);
    padding: 6px 0;
  }

  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }

  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    color: var(--text-light);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    z-index: 1;
  }

  .cal-day:hover {
    background: rgba(255, 105, 180, 0.25);
    transform: scale(1.15);
    box-shadow: 0 2px 10px rgba(255, 105, 180, 0.2);
  }

  .cal-today {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    box-shadow: 0 6px 20px rgba(255, 20, 147, 0.5);
    font-weight: 600;
    animation: today-glow 2s ease-in-out infinite;
  }

  @keyframes today-glow {
    0%, 100% { box-shadow: 0 6px 20px rgba(255, 20, 147, 0.5); }
    50% { box-shadow: 0 8px 25px rgba(255, 20, 147, 0.7); }
  }

  .cal-empty {
    visibility: hidden;
  }

  /* 侧边栏目录 */
  .sidebar-toc {
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.85), rgba(20, 15, 35, 0.9));
    border: 1px solid rgba(255, 105, 180, 0.25);
    border-radius: 24px;
    padding: 22px;
    backdrop-filter: blur(20px);
    box-shadow: 
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .toc-header {
    font-size: 1rem;
    color: var(--secondary);
    margin-bottom: 18px;
    font-weight: 600;
    text-align: center;
    letter-spacing: 1px;
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .toc-item {
    padding: 14px 18px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.1), rgba(168, 85, 247, 0.1));
    border: 1px solid rgba(255, 105, 180, 0.2);
    border-radius: 14px;
    color: var(--accent);
    font-size: 0.9rem;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .toc-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 105, 180, 0.1), transparent);
    transition: left 0.5s ease;
  }

  .toc-item:hover {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.25), rgba(168, 85, 247, 0.25));
    border-color: rgba(255, 105, 180, 0.4);
    transform: translateX(8px);
    box-shadow: 0 4px 15px rgba(255, 105, 180, 0.2);
  }

  .toc-item:hover::before {
    left: 100%;
  }

  /* 侧边栏信息 */
  .sidebar-info {
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.85), rgba(20, 15, 35, 0.9));
    border: 1px solid rgba(255, 105, 180, 0.25);
    border-radius: 24px;
    padding: 22px;
    backdrop-filter: blur(20px);
    box-shadow: 
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 15px;
    background: rgba(255, 105, 180, 0.05);
    border-radius: 12px;
    margin-bottom: 10px;
    transition: all 0.3s ease;
  }

  .info-item:last-child {
    margin-bottom: 0;
  }

  .info-item:hover {
    background: rgba(255, 105, 180, 0.1);
    transform: translateX(5px);
  }

  .info-icon {
    font-size: 1.2rem;
    opacity: 0.8;
  }

  .info-text {
    color: var(--text-light);
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* 主内容区 */
  .post-content-area {
    flex: 1;
    max-width: 950px;
  }

  .post-header {
    text-align: center;
    margin-bottom: 40px;
    padding-bottom: 30px;
    border-bottom: 1px solid rgba(255, 105, 180, 0.1);
    position: relative;
  }

  .post-header::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    border-radius: 2px;
  }

  .post-title {
    font-size: 3rem;
    background: linear-gradient(135deg, var(--text-light), var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 25px;
    font-weight: 700;
    letter-spacing: 2px;
    text-shadow: 0 0 40px rgba(255, 105, 180, 0.3);
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  .post-date {
    color: var(--secondary);
    font-size: 1.1rem;
    letter-spacing: 1px;
  }

  .post-tags {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tag {
    padding: 8px 20px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.15), rgba(168, 85, 247, 0.15));
    border: 1px solid rgba(255, 105, 180, 0.3);
    border-radius: 30px;
    font-size: 0.9rem;
    color: var(--accent);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tag:hover {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.3), rgba(168, 85, 247, 0.3));
    border-color: rgba(255, 105, 180, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(255, 105, 180, 0.2);
  }

  .post-content {
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.9), rgba(20, 15, 35, 0.95));
    border: 1px solid rgba(255, 105, 180, 0.15);
    border-radius: 28px;
    padding: 45px 55px;
    box-shadow: 
      0 25px 80px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
  }

  .post-content::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  /* 代码块样式 */
  .post-content :global(pre) {
    background: linear-gradient(135deg, rgba(20, 15, 35, 0.95), rgba(30, 20, 50, 0.9));
    border: 1px solid rgba(255, 105, 180, 0.3);
    border-radius: 16px;
    padding: 20px;
    padding-top: 40px;
    overflow-x: auto;
    position: relative;
    margin: 20px 0;
  }

  .post-content :global(code) {
    font-family: 'Fira Code', 'Consolas', monospace;
    font-size: 0.85rem;
    line-height: 1.7;
    color: #e0d4f7;
  }

  :global(.code-wrapper) {
    position: relative;
  }

  :global(.copy-btn) {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 6px 12px;
    background: rgba(255, 20, 147, 0.3);
    border: 1px solid rgba(255, 105, 180, 0.5);
    border-radius: 8px;
    color: #FFB6C1;
    font-size: 0.75rem;
    cursor: pointer;
    z-index: 100;
  }

  :global(.copy-btn:hover) {
    background: rgba(255, 20, 147, 0.5);
    transform: scale(1.05);
  }

  :global(.copy-btn.copied) {
    background: rgba(72, 187, 120, 0.3);
    border-color: rgba(72, 187, 120, 0.5);
    color: #68D391;
  }

  .post-content :global(h1) {
    font-size: 2rem;
    color: var(--text-light);
    margin-bottom: 20px;
    border-bottom: 2px solid var(--primary);
    padding-bottom: 10px;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    color: var(--primary);
    margin: 35px 0 20px;
    padding-left: 15px;
    border-left: 4px solid var(--secondary);
  }

  .post-content :global(h3) {
    font-size: 1.2rem;
    color: var(--accent);
    margin: 25px 0 15px;
  }

  .post-content :global(p) {
    color: var(--text-muted);
    line-height: 2.2;
    margin-bottom: 20px;
  }

  .post-content :global(ul), .post-content :global(ol) {
    color: var(--text-muted);
    margin: 15px 0 20px 30px;
    line-height: 2.2;
  }

  .post-content :global(li) {
    margin-bottom: 12px;
    padding-left: 5px;
  }

  .post-content :global(li)::marker {
    color: var(--secondary);
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--glass-border);
    margin: 40px 0;
  }

  .post-content :global(blockquote) {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.1), rgba(255, 105, 180, 0.1));
    border-left: 4px solid var(--primary);
    border-radius: 0 12px 12px 0;
    padding: 20px 25px;
    margin: 25px 0;
    color: var(--accent);
    font-style: italic;
  }

  .post-content :global(em) {
    color: var(--accent);
    font-style: italic;
  }

  .post-content :global(strong) {
    color: var(--primary);
    font-weight: 600;
  }

  .post-content :global(a) {
    color: var(--secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(a:hover) {
    color: var(--primary);
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 20px 0;
    display: block;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 25px 0;
  }

  .post-content :global(th), .post-content :global(td) {
    padding: 12px 15px;
    border: 1px solid var(--glass-border);
    text-align: left;
  }

  .post-content :global(th) {
    background: rgba(255, 20, 147, 0.15);
    color: var(--accent);
  }

  .post-content :global(tr:hover) {
    background: rgba(255, 20, 147, 0.05);
  }

  .back-link {
    display: inline-block;
    margin-top: 40px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: rgba(255, 20, 147, 0.15);
    border: 1px solid rgba(255, 105, 180, 0.3);
    border-radius: 12px;
    color: var(--accent);
    text-decoration: none;
    transition: all 0.3s ease;
    margin-top: 40px;
  }

  .back-button:hover {
    background: rgba(255, 20, 147, 0.3);
    border-color: rgba(255, 105, 180, 0.5);
    transform: translateX(-5px);
  }

  .post-footer {
    text-align: center;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 105, 180, 0.1);
  }

  @media (max-width: 1100px) {
    .post-container {
      flex-direction: column;
      padding: 60px 15px;
      gap: 30px;
    }

    .post-sidebar {
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }

    .sidebar-calendar,
    .sidebar-toc,
    .sidebar-info {
      width: calc(33.33% - 14px);
      min-width: 200px;
    }
      flex-direction: column;
      align-items: center;
    }

    .toc-sidebar {
      position: static;
      width: 100%;
      max-width: 400px;
    }

    .post-title {
      font-size: 2rem;
    }

    .post-content {
      padding: 30px 20px;
    }

    .side-decor {
      display: none;
    }
  }

  /* 移动端显示日历 */
  @media (max-width: 1100px) {
    .side-decor.left {
      position: static;
      transform: none;
      flex-direction: row;
      justify-content: center;
      margin-bottom: 20px;
      gap: 15px;
    }

    .side-decor.left .side-decoration,
    .side-decor.left .side-extra {
      display: none;
    }

    .side-decor.right {
      display: none;
    }
  }
</style>