---
import { getCollection } from 'astro:content';
import NekoLayout from '../../layouts/NekoLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<NekoLayout title={`${post.data.title} - Radiozed`}>
  <!-- 左侧装饰 -->
  <div class="side-decor left">
    <div class="side-date">
      <div class="date-year">{post.data.pubDate.getFullYear()}</div>
      <div class="date-day">{post.data.pubDate.getDate()}</div>
      <div class="date-month">{post.data.pubDate.toLocaleDateString('zh-CN', { month: 'short' })}</div>
    </div>
    <div class="side-decoration">
      <span class="deco-line"></span>
      <span class="deco-icon">✦</span>
      <span class="deco-line"></span>
    </div>
    <div class="side-extra">
      <span class="extra-icon">🌸</span>
      <span class="extra-icon">💫</span>
      <span class="extra-icon">⭐</span>
    </div>
  </div>

  <!-- 右侧装饰 -->
  <div class="side-decor right">
    <div class="side-info">
      <div class="info-label">文章</div>
      <div class="info-value">{post.data.title.length}字</div>
    </div>
    <div class="side-decoration">
      <span class="deco-line"></span>
      <span class="deco-icon">♡</span>
      <span class="deco-line"></span>
    </div>
    <div class="side-extra">
      <span class="extra-icon">🎵</span>
      <span class="extra-icon">✨</span>
      <span class="extra-icon">🌙</span>
    </div>
  </div>

  <article class="post-page">
    <!-- 左侧目录导航 -->
    <nav class="toc-sidebar">
      <div class="toc-title">📑 目录</div>
      <div class="toc-links">
        <a href="#准备工作" class="toc-link">准备工作</a>
        <a href="#代码详解" class="toc-link">代码详解</a>
        <a href="#完整代码" class="toc-link">完整代码</a>
        <a href="#使用说明" class="toc-link">使用说明</a>
        <a href="#注意事项" class="toc-link">注意事项</a>
      </div>
    </nav>

    <div class="post-main">
      <div class="post-header">
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <span class="post-date">📅 {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          {post.data.tags && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>

      <div class="post-content">
        <Content />
      </div>
      <a href="/" class="back-link">← 返回首页</a>
    </div>
  </article>
</NekoLayout>

<script is:inline>
  // 代码块复制功能
  (function() {
    var preBlocks = document.querySelectorAll('pre.astro-code');

    preBlocks.forEach(function(pre) {
      // 创建包装器
      var wrapper = document.createElement('div');
      wrapper.className = 'code-wrapper';
      pre.parentNode.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      // 创建复制按钮
      var copyBtn = document.createElement('button');
      copyBtn.className = 'copy-btn';
      copyBtn.textContent = '📋 复制';

      copyBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var codeEl = pre.querySelector('code');
        var code = codeEl ? codeEl.textContent : pre.textContent;
        navigator.clipboard.writeText(code).then(function() {
          copyBtn.textContent = '✅ 已复制!';
          copyBtn.classList.add('copied');
          setTimeout(function() {
            copyBtn.textContent = '📋 复制';
            copyBtn.classList.remove('copied');
          }, 2000);
        }).catch(function() {
          copyBtn.textContent = '❌ 失败';
        });
      });

      wrapper.appendChild(copyBtn);
    });
  })();
</script>

<style>
  .post-page {
    display: flex;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 20px 80px;
  }

  /* 左侧目录 */
  .toc-sidebar {
    position: fixed;
    left: 40px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(20, 15, 35, 0.6);
    border: 1px solid rgba(255, 105, 180, 0.2);
    border-radius: 16px;
    padding: 25px 20px;
    backdrop-filter: blur(10px);
    width: 140px;
  }

  .toc-sidebar .toc-title {
    font-size: 0.9rem;
    color: var(--secondary);
    margin-bottom: 15px;
    font-weight: 600;
    text-align: center;
  }

  .toc-sidebar .toc-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .toc-sidebar .toc-link {
    padding: 10px 15px;
    background: rgba(255, 20, 147, 0.15);
    border: 1px solid rgba(255, 105, 180, 0.3);
    border-radius: 12px;
    color: var(--accent);
    font-size: 0.8rem;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
  }

  .toc-sidebar .toc-link:hover {
    background: rgba(255, 20, 147, 0.3);
    border-color: rgba(255, 105, 180, 0.5);
    transform: translateX(5px);
  }

  .post-main {
    flex: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .post-header {
    text-align: center;
    margin-bottom: 30px;
  }

  .post-title {
    font-size: 2.8rem;
    background: linear-gradient(135deg, var(--text-light), var(--primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 20px;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
  }

  .post-date {
    color: var(--secondary);
    font-size: 1rem;
  }

  .post-tags {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 6px 18px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.2), rgba(255, 105, 180, 0.2));
    border: 1px solid rgba(255, 105, 180, 0.4);
    border-radius: 30px;
    font-size: 0.85rem;
    color: var(--accent);
  }

  .post-content {
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 30px;
    padding: 50px 60px;
    backdrop-filter: blur(15px);
    position: relative;
  }

  .post-content::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, var(--primary), var(--secondary), transparent);
    border-radius: 30px 30px 0 0;
  }

  /* 代码块样式 */
  .post-content :global(pre) {
    background: linear-gradient(135deg, rgba(20, 15, 35, 0.95), rgba(30, 20, 50, 0.9));
    border: 1px solid rgba(255, 105, 180, 0.3);
    border-radius: 16px;
    padding: 20px;
    padding-top: 40px;
    overflow-x: auto;
    position: relative;
    margin: 20px 0;
  }

  .post-content :global(code) {
    font-family: 'Fira Code', 'Consolas', monospace;
    font-size: 0.85rem;
    line-height: 1.7;
    color: #e0d4f7;
  }

  :global(.code-wrapper) {
    position: relative;
  }

  :global(.copy-btn) {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 6px 12px;
    background: rgba(255, 20, 147, 0.3);
    border: 1px solid rgba(255, 105, 180, 0.5);
    border-radius: 8px;
    color: #FFB6C1;
    font-size: 0.75rem;
    cursor: pointer;
    z-index: 100;
  }

  :global(.copy-btn:hover) {
    background: rgba(255, 20, 147, 0.5);
    transform: scale(1.05);
  }

  :global(.copy-btn.copied) {
    background: rgba(72, 187, 120, 0.3);
    border-color: rgba(72, 187, 120, 0.5);
    color: #68D391;
  }
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 6px 12px;
    background: rgba(255, 20, 147, 0.4) !important;
    border: 2px solid rgba(255, 105, 180, 0.6);
    border-radius: 8px;
    color: #fff !important;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 9999 !important;
    display: flex !important;
    align-items: center;
    gap: 4px;
  }

  :global(.copy-btn:hover) {
    background: rgba(255, 20, 147, 0.7) !important;
    transform: scale(1.1);
  }

  :global(.copy-btn.copied) {
    background: rgba(72, 187, 120, 0.3);
    border-color: rgba(72, 187, 120, 0.5);
    color: #68D391;
  }

  .post-content :global(h1) {
    font-size: 2rem;
    color: var(--text-light);
    margin-bottom: 20px;
    border-bottom: 2px solid var(--primary);
    padding-bottom: 10px;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    color: var(--primary);
    margin: 35px 0 20px;
    padding-left: 15px;
    border-left: 4px solid var(--secondary);
  }

  .post-content :global(h3) {
    font-size: 1.2rem;
    color: var(--accent);
    margin: 25px 0 15px;
  }

  .post-content :global(p) {
    color: var(--text-muted);
    line-height: 2.2;
    margin-bottom: 20px;
  }

  .post-content :global(ul), .post-content :global(ol) {
    color: var(--text-muted);
    margin: 15px 0 20px 30px;
    line-height: 2.2;
  }

  .post-content :global(li) {
    margin-bottom: 12px;
    padding-left: 5px;
  }

  .post-content :global(li)::marker {
    color: var(--secondary);
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--glass-border);
    margin: 40px 0;
  }

  .post-content :global(blockquote) {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.1), rgba(255, 105, 180, 0.1));
    border-left: 4px solid var(--primary);
    border-radius: 0 12px 12px 0;
    padding: 20px 25px;
    margin: 25px 0;
    color: var(--accent);
    font-style: italic;
  }

  .post-content :global(em) {
    color: var(--accent);
    font-style: italic;
  }

  .post-content :global(strong) {
    color: var(--primary);
    font-weight: 600;
  }

  .post-content :global(a) {
    color: var(--secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(a:hover) {
    color: var(--primary);
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 25px 0;
  }

  .post-content :global(th), .post-content :global(td) {
    padding: 12px 15px;
    border: 1px solid var(--glass-border);
    text-align: left;
  }

  .post-content :global(th) {
    background: rgba(255, 20, 147, 0.15);
    color: var(--accent);
  }

  .post-content :global(tr:hover) {
    background: rgba(255, 20, 147, 0.05);
  }

  .back-link {
    display: inline-block;
    margin-top: 40px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .back-link:hover {
    color: var(--primary);
    transform: translateX(-5px);
  }

  /* 侧边装饰 */
  .side-decor {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    z-index: 100;
  }

  .side-decor.left {
    left: 25px;
  }

  .side-decor.right {
    right: 25px;
  }

  .side-date {
    background: rgba(20, 15, 35, 0.8);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 105, 180, 0.2);
    border-radius: 16px;
    padding: 15px 20px;
    text-align: center;
  }

  .side-info {
    background: rgba(20, 15, 35, 0.8);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 105, 180, 0.2);
    border-radius: 16px;
    padding: 12px 18px;
    text-align: center;
  }

  .info-label {
    font-size: 0.7rem;
    color: var(--secondary);
  }

  .info-value {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-light);
  }

  .date-year {
    font-size: 0.8rem;
    color: var(--secondary);
    font-weight: 500;
  }

  .date-day {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-light);
    line-height: 1.2;
  }

  .date-month {
    font-size: 0.8rem;
    color: var(--accent);
  }

  .side-extra {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .extra-icon {
    font-size: 1.2rem;
    opacity: 0.5;
    animation: float 3s ease-in-out infinite;
  }

  .extra-icon:nth-child(2) {
    animation-delay: -1s;
  }

  .extra-icon:nth-child(3) {
    animation-delay: -2s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  .side-decoration {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0.6;
  }

  .deco-line {
    width: 2px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--primary), transparent);
  }

  .deco-icon {
    color: var(--primary);
    font-size: 1rem;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  @media (max-width: 768px) {
    .post-page {
      padding: 100px 15px 60px;
    }

    .toc-sidebar {
      display: none;
    }

    .post-title {
      font-size: 2rem;
    }

    .post-content {
      padding: 30px 20px;
    }

    .side-decor {
      display: none;
    }

    .side-decor {
      display: none;
    }
  }
</style>