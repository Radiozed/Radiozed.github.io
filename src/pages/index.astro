---
import { getCollection } from 'astro:content';
import NekoLayout from '../layouts/NekoLayout.astro';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<NekoLayout title="Radiozed - 喵的小屋">
  <!-- 动态背景粒子 -->
  <div class="particles">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
  </div>

  <section class="hero">
    <!-- 右上角信息面板 -->
    <div class="info-panel">
      <div class="clock">
        <span class="clock-icon">🕐</span>
        <span id="current-time">--:--:--</span>
      </div>
      <div class="date-display">
        <span id="current-date">2024年1月1日</span>
      </div>
    </div>

    <div class="hero-avatar">
      <img src="/nekomusume.jpg" alt="猫娘头像" />
      <div class="avatar-glow"></div>
      <div class="avatar-ring"></div>
    </div>
    <h1 class="title-animate">我是 Radiozed~</h1>
    <p class="subtitle">一个热爱技术&amp;二次元的普通大学生</p>
    <p class="greeting">喜欢嵌入式开发、动漫和音乐，欢迎来到我的小世界！🐾</p>
    <div class="hero-buttons">
      <a href="/posts" class="btn btn-primary">查看文章 ✦</a>
      <a href="/gallery" class="btn btn-secondary">艺术作品 ♡</a>
    </div>

    <!-- 浮动装饰 -->
    <div class="floating-items">
      <span class="float-item" style="--delay:0s">✦</span>
      <span class="float-item" style="--delay:1s">♡</span>
      <span class="float-item" style="--delay:2s">⭐</span>
      <span class="float-item" style="--delay:0.5s">🌸</span>
      <span class="float-item" style="--delay:1.5s">💫</span>
      <span class="float-item" style="--delay:2.5s">✨</span>
      <span class="float-item" style="--delay:3s">🎀</span>
    </div>

    <!-- 装饰性丝带 -->
    <div class="ribbon ribbon-left">
      <span>~ ♡ ~</span>
    </div>
    <div class="ribbon ribbon-right">
      <span>~ ♡ ~</span>
    </div>
  </section>

  <section class="calendar-section" id="calendar-section" style="display:none;">
    <h2 class="section-title"><span>📅</span> 今日日程</h2>
    <p class="section-subtitle">今天也要元气满满哦！♡</p>
    
    <div class="calendar-container">
      <div class="calendar-header">
        <button class="calendar-nav" id="prev-month">‹</button>
        <h3 id="calendar-title">2024年1月</h3>
        <button class="calendar-nav" id="next-month">›</button>
      </div>
      
      <div class="calendar-weekdays">
        <span>日</span>
        <span>一</span>
        <span>二</span>
        <span>三</span>
        <span>四</span>
        <span>五</span>
        <span>六</span>
      </div>
      
      <div class="calendar-days" id="calendar-days">
        <!-- JavaScript 动态生成 -->
      </div>
      
      <div class="today-highlight">
        <span id="today-text">今天是</span>
        <span id="today-date-display"></span>
      </div>
    </div>
  </section>

  <section class="posts-section" id="posts" style="display:none;">
    <h2 class="section-title"><span>✦</span> 全部文章</h2>
    <p class="section-subtitle">记录一些有趣的想法和创作过程~</p>

    <div class="posts-grid">
      {sortedPosts.map((post) => (
        <a href={`/posts/${post.slug}`} class="post-card fade-in">
          <div class="post-date">{post.data.pubDate.toLocaleDateString('zh-CN')}</div>
          <h3 class="post-title">{post.data.title}</h3>
          <p class="post-excerpt">{post.data.description}</p>
          {post.data.tags && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>

  <section class="gallery-section" id="gallery" style="display:none;">
    <h2 class="section-title"><span>✦</span> 艺术作品</h2>
    <p class="section-subtitle">一些喜欢的创作作品~</p>
    <div class="gallery-grid">
      <div class="gallery-item fade-in">
        <img src="/gallery1.jpg" alt="猫娘插画 1" loading="lazy" />
        <div class="gallery-overlay">
          <h4>♥ Nekomimi ♡</h4>
          <p>~ 猫耳少女 ~</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery2.jpg" alt="猫娘插画 2" loading="lazy" />
        <div class="gallery-overlay">
          <h4>♡ Neko ♡</h4>
          <p>~ 可爱的猫娘 ~</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery3.jpg" alt="猫娘插画 3" loading="lazy" />
        <div class="gallery-overlay">
          <h4>✦ Meow ✦</h4>
          <p>~ 喵~ 🐾</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery4.jpg" alt="猫娘插画 4" loading="lazy" />
        <div class="gallery-overlay">
          <h4>★ Neko ★</h4>
          <p>~ 二次元猫娘 ~</p>
        </div>
      </div>
    </div>
  </section>
</NekoLayout>

<style>
  /* 信息面板 */
  .info-panel {
    position: absolute;
    top: 80px;
    right: 30px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 15px 22px;
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.85), rgba(20, 15, 35, 0.9));
    border-radius: 18px;
    border: 1px solid rgba(255, 105, 180, 0.18);
    backdrop-filter: blur(20px);
    z-index: 10;
    animation: slide-in-right 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.3s both;
    box-shadow: 0 8px 32px rgba(255, 20, 147, 0.12);
  }

  @keyframes slide-in-right {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .clock {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.15rem;
    color: var(--accent);
    font-family: 'Courier New', monospace;
    letter-spacing: 2px;
  }

  .clock-icon {
    font-size: 1.4rem;
    animation: bounce 1s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  #current-time {
    font-weight: 600;
    text-shadow: 0 0 20px rgba(255, 20, 147, 0.5);
  }

  .date-display {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
    padding-top: 5px;
    border-top: 1px solid rgba(255, 105, 180, 0.15);
  }

  /* 头像圆环装饰 */
  .avatar-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 160px;
    height: 160px;
    transform: translate(-50%, -50%);
    border: 2px solid transparent;
    border-radius: 50%;
    background: linear-gradient(var(--bg-dark), var(--bg-dark)) padding-box,
                linear-gradient(135deg, var(--primary), var(--secondary), var(--accent)) border-box;
    animation: ring-rotate 8s linear infinite;
    pointer-events: none;
  }

  @keyframes ring-rotate {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* 装饰丝带 */
  .ribbon {
    position: absolute;
    top: 40%;
    padding: 8px 25px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    border-radius: 25px;
    transform: rotate(-15deg);
    opacity: 0.7;
    animation: ribbon-wave 3s ease-in-out infinite;
    z-index: 5;
  }

  .ribbon-left {
    left: -80px;
    animation-delay: 0s;
  }

  .ribbon-right {
    right: -80px;
    transform: rotate(15deg);
    animation-delay: 1.5s;
  }

  .ribbon span {
    color: white;
    font-weight: 600;
    font-size: 0.9rem;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  @keyframes ribbon-wave {
    0%, 100% { transform: rotate(-15deg) translateY(0); }
    50% { transform: rotate(-15deg) translateY(-10px); }
  }

  .ribbon-right {
    animation-name: ribbon-wave-right;
  }

  @keyframes ribbon-wave-right {
    0%, 100% { transform: rotate(15deg) translateY(0); }
    50% { transform: rotate(15deg) translateY(-10px); }
  }

  /* 动态粒子背景 */
  .particles {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--primary);
    border-radius: 50%;
    opacity: 0.3;
    animation: float-particle 15s infinite linear;
  }

  .particle:nth-child(1) { left: 10%; animation-duration: 12s; animation-delay: 0s; }
  .particle:nth-child(2) { left: 25%; animation-duration: 18s; animation-delay: 2s; }
  .particle:nth-child(3) { left: 50%; animation-duration: 14s; animation-delay: 4s; }
  .particle:nth-child(4) { left: 75%; animation-duration: 16s; animation-delay: 1s; }
  .particle:nth-child(5) { left: 90%; animation-duration: 20s; animation-delay: 3s; }

  @keyframes float-particle {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.4; }
    90% { opacity: 0.4; }
    100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
  }

  /* 头像光晕 */
  .hero-avatar {
    position: relative;
  }

  .avatar-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 150px;
    height: 150px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(255, 105, 180, 0.4) 0%, transparent 70%);
    animation: glow-pulse 2s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glow-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
    50% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
  }

  /* 标题动画 */
  .title-animate {
    animation: title-float 3s ease-in-out infinite;
  }

  @keyframes title-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* 打字机效果 */
  .typing-text {
    overflow: hidden;
    white-space: nowrap;
    animation: typing 3s steps(20) forwards;
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 100%; }
  }

  /* 浮动装饰 */
  .floating-items {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
  }

  .float-item {
    position: absolute;
    font-size: 1.5rem;
    opacity: 0.4;
    animation: float-up 4s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .float-item:nth-child(1) { left: 10%; top: 20%; }
  .float-item:nth-child(2) { right: 15%; top: 30%; }
  .float-item:nth-child(3) { left: 20%; bottom: 25%; }
  .float-item:nth-child(4) { right: 20%; bottom: 20%; }
  .float-item:nth-child(5) { left: 50%; top: 15%; }

  @keyframes float-up {
    0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.3; }
    50% { transform: translateY(-20px) rotate(180deg); opacity: 0.7; }
  }

  .posts-section {
    padding: 120px 20px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  
  .posts-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 100%;
    background: linear-gradient(180deg, rgba(255, 20, 147, 0.05) 0%, transparent 100%);
    border-radius: 0 0 50% 50%;
    pointer-events: none;
  }

  .gallery-section {
    padding: 120px 40px;
    max-width: 1400px;
    margin: 0 auto 80px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.06), rgba(168, 85, 247, 0.06));
    border: 1px solid rgba(255, 105, 180, 0.12);
    border-radius: 50px;
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
  }

  .gallery-section::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.08) 0%, transparent 50%);
    animation: rotate 35s linear infinite;
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .section-title {
    font-size: 2.8rem;
    text-align: center;
    margin-bottom: 15px;
    font-weight: 700;
    position: relative;
    background: linear-gradient(135deg, var(--text-light), var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 3px;
  }

  .section-title span {
    display: inline-block;
    margin-right: 10px;
    animation: starPulse 2s ease-in-out infinite;
  }

  @keyframes starPulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.15rem;
    color: var(--text-muted);
    margin-bottom: 60px;
    font-weight: 300;
    letter-spacing: 2px;
    opacity: 0.8;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
    position: relative;
    z-index: 1;
  }

  .post-card {
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.9), rgba(20, 15, 35, 0.95));
    border-radius: 20px;
    padding: 28px 32px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 105, 180, 0.12);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(15px);
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--primary), var(--secondary), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .post-card:hover::before {
    opacity: 1;
  }

  .post-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 105, 180, 0.08), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .post-card:hover {
    transform: translateY(-8px) scale(1.01);
    border-color: rgba(255, 105, 180, 0.35);
    box-shadow: 
      0 25px 60px rgba(255, 20, 147, 0.2),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--secondary);
    font-weight: 400;
    letter-spacing: 0.5px;
    flex-shrink: 0;
    width: 90px;
  }

  .post-title {
    font-size: 1.1rem;
    color: var(--text-light);
    font-weight: 600;
    line-height: 1.4;
    flex: 1;
  }

  .post-excerpt {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 2;
  }

  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .tag {
    padding: 5px 14px;
    background: rgba(255, 20, 147, 0.12);
    border: 1px solid rgba(255, 105, 180, 0.25);
    border-radius: 18px;
    font-size: 0.78rem;
    color: var(--accent);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .tag:hover {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.3), rgba(255, 105, 180, 0.3));
    transform: scale(1.1) translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 20, 147, 0.25);
    border-color: var(--primary);
  }

  .gallery-item {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    aspect-ratio: 3/4;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 105, 180, 0.12);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gallery-item:hover img {
    transform: scale(1.1);
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 35px 25px;
    background: linear-gradient(transparent, rgba(13, 11, 20, 0.95) 45%);
    transform: translateY(70px);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: center;
  }

  .gallery-item:hover .gallery-overlay {
    transform: translateY(0);
  }

  .gallery-overlay h4 {
    color: var(--accent);
    margin-bottom: 10px;
    font-size: 1.35rem;
    font-weight: 600;
    text-shadow: 0 3px 15px rgba(255, 20, 147, 0.6);
    letter-spacing: 1px;
  }

  .gallery-overlay p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1rem;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-light);
    border: 2px solid var(--secondary);
  }

  .btn-secondary:hover {
    background: var(--secondary);
  }

  .fade-in {
    opacity: 0;
    transform: translateY(35px);
    transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* 日历组件 */
  .calendar-section {
    padding: 100px 20px;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }

  .calendar-container {
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.9), rgba(20, 15, 35, 0.95));
    border-radius: 28px;
    padding: 35px;
    border: 1px solid rgba(255, 105, 180, 0.15);
    backdrop-filter: blur(20px);
    box-shadow: 0 25px 60px rgba(255, 20, 147, 0.12);
    position: relative;
    overflow: hidden;
  }

  .calendar-container::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 150%;
    height: 150%;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.08) 0%, transparent 60%);
    animation: rotate-slow 40s linear infinite;
  }

  @keyframes rotate-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    position: relative;
    z-index: 1;
  }

  .calendar-nav {
    width: 45px;
    height: 45px;
    border: none;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.2), rgba(168, 85, 247, 0.2));
    color: var(--accent);
    font-size: 1.5rem;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 105, 180, 0.25);
  }

  .calendar-nav:hover {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    transform: scale(1.1);
    box-shadow: 0 8px 25px rgba(255, 20, 147, 0.3);
  }

  #calendar-title {
    font-size: 1.4rem;
    color: var(--text-light);
    font-weight: 600;
    letter-spacing: 2px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
    margin-bottom: 15px;
    position: relative;
    z-index: 1;
  }

  .calendar-weekdays span {
    text-align: center;
    padding: 12px 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 10px;
  }

  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
    position: relative;
    z-index: 1;
  }

  .calendar-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.95rem;
    color: var(--text-light);
    border: 1px solid transparent;
  }

  .calendar-day:hover {
    background: rgba(255, 105, 180, 0.15);
    border-color: rgba(255, 105, 180, 0.3);
    transform: scale(1.05);
  }

  .calendar-day.empty {
    background: transparent;
    cursor: default;
    opacity: 0;
  }

  .calendar-day.today {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    box-shadow: 0 8px 25px rgba(255, 20, 147, 0.4);
    animation: today-pulse 2s ease-in-out infinite;
  }

  @keyframes today-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }

