---
import { getCollection } from 'astro:content';
import NekoLayout from '../layouts/NekoLayout.astro';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<NekoLayout title="Radiozed - 喵的小屋">
  <!-- 动态背景粒子 -->
  <div class="particles">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
  </div>

  <section class="hero">
    <div class="hero-avatar">
      <img src="/nekomusume.jpg" alt="猫娘头像" />
      <div class="avatar-glow"></div>
    </div>
    <h1 class="title-animate">我是 Radiozed~</h1>
    <p class="subtitle typing-text">一个热爱技术&二次元的普通大学生</p>
    <p class="greeting">喜欢嵌入式开发、动漫和音乐，欢迎来到我的小世界！🐾</p>
    <div class="hero-buttons">
      <a href="/posts" class="btn btn-primary">查看文章 ✦</a>
      <a href="/gallery" class="btn btn-secondary">艺术作品 ♡</a>
    </div>

    <!-- 浮动装饰 -->
    <div class="floating-items">
      <span class="float-item" style="--delay:0s">✦</span>
      <span class="float-item" style="--delay:1s">♡</span>
      <span class="float-item" style="--delay:2s">⭐</span>
      <span class="float-item" style="--delay:0.5s">🌸</span>
      <span class="float-item" style="--delay:1.5s">💫</span>
    </div>
  </section>

  <section class="posts-section" id="posts" style="display:none;">
    <h2 class="section-title"><span>✦</span> 全部文章</h2>
    <p class="section-subtitle">记录一些有趣的想法和创作过程~</p>

    <div class="posts-grid">
      {sortedPosts.map((post) => (
        <a href={`/posts/${post.slug}`} class="post-card fade-in">
          <div class="post-date">{post.data.pubDate.toLocaleDateString('zh-CN')}</div>
          <h3 class="post-title">{post.data.title}</h3>
          <p class="post-excerpt">{post.data.description}</p>
          {post.data.tags && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>

  <section class="gallery-section" id="gallery" style="display:none;">
    <h2 class="section-title"><span>✦</span> 艺术作品</h2>
    <p class="section-subtitle">一些喜欢的创作作品~</p>
    <div class="gallery-grid">
      <div class="gallery-item fade-in">
        <img src="/gallery1.jpg" alt="猫娘插画 1" loading="lazy" />
        <div class="gallery-overlay">
          <h4>♥ Nekomimi ♡</h4>
          <p>~ 猫耳少女 ~</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery2.jpg" alt="猫娘插画 2" loading="lazy" />
        <div class="gallery-overlay">
          <h4>♡ Neko ♡</h4>
          <p>~ 可爱的猫娘 ~</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery3.jpg" alt="猫娘插画 3" loading="lazy" />
        <div class="gallery-overlay">
          <h4>✦ Meow ✦</h4>
          <p>~ 喵~ 🐾</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery4.jpg" alt="猫娘插画 4" loading="lazy" />
        <div class="gallery-overlay">
          <h4>★ Neko ★</h4>
          <p>~ 二次元猫娘 ~</p>
        </div>
      </div>
    </div>
  </section>
</NekoLayout>

<style>
  /* 动态粒子背景 */
  .particles {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--primary);
    border-radius: 50%;
    opacity: 0.3;
    animation: float-particle 15s infinite linear;
  }

  .particle:nth-child(1) { left: 10%; animation-duration: 12s; animation-delay: 0s; }
  .particle:nth-child(2) { left: 25%; animation-duration: 18s; animation-delay: 2s; }
  .particle:nth-child(3) { left: 50%; animation-duration: 14s; animation-delay: 4s; }
  .particle:nth-child(4) { left: 75%; animation-duration: 16s; animation-delay: 1s; }
  .particle:nth-child(5) { left: 90%; animation-duration: 20s; animation-delay: 3s; }

  @keyframes float-particle {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.4; }
    90% { opacity: 0.4; }
    100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
  }

  /* 头像光晕 */
  .hero-avatar {
    position: relative;
  }

  .avatar-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 150px;
    height: 150px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(255, 105, 180, 0.4) 0%, transparent 70%);
    animation: glow-pulse 2s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glow-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
    50% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
  }

  /* 标题动画 */
  .title-animate {
    animation: title-float 3s ease-in-out infinite;
  }

  @keyframes title-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* 打字机效果 */
  .typing-text {
    overflow: hidden;
    white-space: nowrap;
    animation: typing 3s steps(20) forwards;
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 100%; }
  }

  /* 浮动装饰 */
  .floating-items {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
  }

  .float-item {
    position: absolute;
    font-size: 1.5rem;
    opacity: 0.4;
    animation: float-up 4s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .float-item:nth-child(1) { left: 10%; top: 20%; }
  .float-item:nth-child(2) { right: 15%; top: 30%; }
  .float-item:nth-child(3) { left: 20%; bottom: 25%; }
  .float-item:nth-child(4) { right: 20%; bottom: 20%; }
  .float-item:nth-child(5) { left: 50%; top: 15%; }

  @keyframes float-up {
    0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.3; }
    50% { transform: translateY(-20px) rotate(180deg); opacity: 0.7; }
  }

  .posts-section {
    padding: 120px 20px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  
  .posts-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 100%;
    background: linear-gradient(180deg, rgba(255, 20, 147, 0.05) 0%, transparent 100%);
    border-radius: 0 0 50% 50%;
    pointer-events: none;
  }

  .gallery-section {
    padding: 120px 40px;
    max-width: 1400px;
    margin: 0 auto 80px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.08), rgba(168, 85, 247, 0.08));
    border: 1px solid rgba(255, 105, 180, 0.15);
    border-radius: 50px;
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
  }

  .gallery-section::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.1) 0%, transparent 50%);
    animation: rotate 30s linear infinite;
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .section-title {
    font-size: 3rem;
    text-align: center;
    margin-bottom: 15px;
    font-weight: 700;
    position: relative;
    background: linear-gradient(135deg, var(--text-light), var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 60px;
    font-weight: 300;
    letter-spacing: 2px;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
    position: relative;
    z-index: 1;
  }

  .post-card {
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.9), rgba(20, 15, 35, 0.95));
    border-radius: 16px;
    padding: 25px 30px;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 105, 180, 0.15);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(15px);
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, var(--primary), var(--secondary), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .post-card:hover::before {
    opacity: 1;
  }

  .post-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 105, 180, 0.1), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .post-card:hover::after {
    opacity: 1;
  }

  .post-card:hover {
    transform: translateY(-15px) scale(1.02);
    border-color: rgba(255, 105, 180, 0.4);
    box-shadow: 
      0 30px 80px rgba(255, 20, 147, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.08) inset;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--secondary);
    font-weight: 400;
    letter-spacing: 0.5px;
    flex-shrink: 0;
    width: 90px;
  }

  .post-title {
    font-size: 1.1rem;
    color: var(--text-light);
    font-weight: 600;
    line-height: 1.4;
    flex: 1;
  }

  .post-excerpt {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 2;
  }

  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .tag {
    padding: 4px 12px;
    background: rgba(255, 20, 147, 0.15);
    border: 1px solid rgba(255, 105, 180, 0.3);
    border-radius: 15px;
    font-size: 0.75rem;
    color: var(--accent);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .tag:hover {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.35), rgba(255, 105, 180, 0.35));
    transform: scale(1.1) translateY(-2px);
    box-shadow: 0 5px 20px rgba(255, 20, 147, 0.3);
  }

  .gallery-item {
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    aspect-ratio: 3/4;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 105, 180, 0.15);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.08);
  }
    justify-content: center;
    align-items: center;
    transition: transform 0.4s ease;
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px 25px;
    background: linear-gradient(transparent, rgba(13, 11, 20, 0.95) 40%);
    transform: translateY(60px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: center;
  }

  .gallery-item:hover .gallery-overlay {
    transform: translateY(0);
  }

  .gallery-overlay h4 {
    color: var(--accent);
    margin-bottom: 8px;
    font-size: 1.3rem;
    font-weight: 600;
    text-shadow: 0 2px 10px rgba(255, 20, 147, 0.5);
  }

  .gallery-overlay p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-light);
    border: 2px solid var(--secondary);
  }

  .btn-secondary:hover {
    background: var(--secondary);
  }

  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>