<script>
  // 时钟功能
  function updateTime() {
    const now = new Date();
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    const seconds = String(now.getSeconds()).padStart(2, '0');
    document.getElementById('current-time').textContent = `${hours}:${minutes}:${seconds}`;
    
    const year = now.getFullYear();
    const month = now.getMonth() + 1;
    const day = now.getDate();
    const weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
    const weekday = weekdays[now.getDay()];
    document.getElementById('current-date').textContent = `${year}年${month}月${day}日 ${weekday}`;
    document.getElementById('today-date-display').textContent = `${year}年${month}月${day}日 ${weekday}`;
  }

  // 日历功能
  let currentDate = new Date();
  let today = new Date();

  function generateCalendar(year, month) {
    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const daysContainer = document.getElementById('calendar-days');
    const titleElement = document.getElementById('calendar-title');
    
    titleElement.textContent = `${year}年${month + 1}月`;
    daysContainer.innerHTML = '';

    const startDay = firstDay.getDay();
    const totalDays = lastDay.getDate();

    // 填充上月空白
    const prevMonthLastDay = new Date(year, month, 0).getDate();
    for (let i = startDay - 1; i >= 0; i--) {
      const dayElement = document.createElement('div');
      dayElement.className = 'calendar-day empty';
      daysContainer.appendChild(dayElement);
    }

    // 填充当月日期
    for (let day = 1; day <= totalDays; day++) {
      const dayElement = document.createElement('div');
      dayElement.className = 'calendar-day';
      dayElement.textContent = day;
      
      const isToday = today.getFullYear() === year && 
                      today.getMonth() === month && 
                      today.getDate() === day;
      
      if (isToday) {
        dayElement.classList.add('today');
      }

      daysContainer.appendChild(dayElement);
    }

    // 填充下月空白
    const remainingCells = 42 - (startDay + totalDays);
    for (let i = 1; i <= remainingCells; i++) {
      const dayElement = document.createElement('div');
      dayElement.className = 'calendar-day empty';
      daysContainer.appendChild(dayElement);
    }
  }

  function prevMonth() {
    currentDate.setMonth(currentDate.getMonth() - 1);
    generateCalendar(currentDate.getFullYear(), currentDate.getMonth());
  }

  function nextMonth() {
    currentDate.setMonth(currentDate.getMonth() + 1);
    generateCalendar(currentDate.getFullYear(), currentDate.getMonth());
  }

  // 页面加载时初始化
  document.addEventListener('DOMContentLoaded', function() {
    updateTime();
    setInterval(updateTime, 1000);
    
    generateCalendar(currentDate.getFullYear(), currentDate.getMonth());
    
    document.getElementById('prev-month')?.addEventListener('click', prevMonth);
    document.getElementById('next-month')?.addEventListener('click', nextMonth);
  });
</script>