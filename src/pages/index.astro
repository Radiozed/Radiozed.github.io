---
import { getCollection } from 'astro:content';
import NekoLayout from '../layouts/NekoLayout.astro';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 按标签分组文章
const tags = ['STM32', 'MAX31865', 'PT100', 'ESP32', 'OneNET'];
const postsByTag = {};
tags.forEach(tag => {
  postsByTag[tag] = sortedPosts.filter(post =>
    post.data.tags?.some(t => t.toLowerCase().includes(tag.toLowerCase()))
  );
});
// 添加未分类的文章
const uncategorized = sortedPosts.filter(post =>
  !post.data.tags?.some(t => tags.some(tag => t.toLowerCase().includes(tag.toLowerCase())))
);
if (uncategorized.length > 0) {
  postsByTag['其他'] = uncategorized;
}
---

<script is:inline>
  // 分类切换功能
  document.querySelectorAll('.category-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var category = this.dataset.category;

      // 更新按钮状态
      document.querySelectorAll('.category-btn').forEach(function(b) {
        b.classList.remove('active');
      });
      this.classList.add('active');

      // 显示对应的文章组
      document.querySelectorAll('.posts-group').forEach(function(group) {
        if (group.dataset.posts === category) {
          group.classList.add('active');
        } else {
          group.classList.remove('active');
        }
      });
    });
  });
</script>

<NekoLayout title="Radiozed - 喵的小屋">
  <section class="hero">
    <div class="hero-avatar">
      <img src="/nekomusume.jpg" alt="猫娘头像" />
    </div>
    <h1>喵的创作小屋</h1>
    <p class="subtitle">欢迎来到 Radiozed 的小天地~ 这里是存放创意作品和想法的地方</p>
    <p class="greeting">希望你能喜欢喵！🐾</p>
    <div class="hero-buttons">
      <a href="#posts" class="btn btn-primary">开始浏览 ✦</a>
      <a href="#gallery" class="btn btn-secondary">看看作品</a>
    </div>
  </section>

  <section class="posts-section" id="posts">
    <h2 class="section-title"><span>✦</span> 文章分类</h2>
    <p class="section-subtitle">记录一些有趣的想法和创作过程~</p>

    <!-- 分类导航 -->
    <div class="category-nav">
      {Object.keys(postsByTag).map((tag, index) => (
        <button class={`category-btn ${index === 0 ? 'active' : ''}`} data-category={tag}>
          {tag}
          <span class="category-count">{postsByTag[tag].length}</span>
        </button>
      ))}
    </div>

    <!-- 分类内容 -->
    <div class="posts-container">
      {Object.entries(postsByTag).map(([tag, tagPosts], index) => (
        <div class={`posts-group ${index === 0 ? 'active' : ''}`} data-posts={tag}>
          <h3 class="group-title">{tag}</h3>
          <div class="posts-grid">
            {tagPosts.map((post) => (
              <a href={`/posts/${post.slug}`} class="post-card fade-in">
                <div class="post-date">{post.data.pubDate.toLocaleDateString('zh-CN')}</div>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-excerpt">{post.data.description}</p>
                {post.data.tags && (
                  <div class="post-tags">
                    {post.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="gallery-section" id="gallery">
    <h2 class="section-title"><span>✦</span> 艺术作品</h2>
    <p class="section-subtitle">一些喜欢的创作作品~</p>
    <div class="gallery-grid">
      <div class="gallery-item fade-in">
        <img src="/gallery1.jpg" alt="猫娘插画 1" loading="lazy" />
        <div class="gallery-overlay">
          <h4>♥ Nekomimi ♡</h4>
          <p>~ 猫耳少女 ~</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery2.jpg" alt="猫娘插画 2" loading="lazy" />
        <div class="gallery-overlay">
          <h4>♡ Neko ♡</h4>
          <p>~ 可爱的猫娘 ~</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery3.jpg" alt="猫娘插画 3" loading="lazy" />
        <div class="gallery-overlay">
          <h4>✦ Meow ✦</h4>
          <p>~ 喵~ 🐾</p>
        </div>
      </div>
      <div class="gallery-item fade-in">
        <img src="/gallery4.jpg" alt="猫娘插画 4" loading="lazy" />
        <div class="gallery-overlay">
          <h4>★ Neko ★</h4>
          <p>~ 二次元猫娘 ~</p>
        </div>
      </div>
    </div>
  </section>
</NekoLayout>

<style>
  .posts-section {
    padding: 120px 20px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  /* 分类导航 */
  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    justify-content: center;
    margin-bottom: 50px;
  }

  .category-btn {
    padding: 12px 28px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 105, 180, 0.2);
    border-radius: 30px;
    color: var(--text-muted);
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .category-btn:hover {
    background: rgba(255, 20, 147, 0.2);
    border-color: rgba(255, 105, 180, 0.4);
    color: var(--text-light);
  }

  .category-btn.active {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.3), rgba(255, 105, 180, 0.3));
    border-color: var(--primary);
    color: var(--accent);
    box-shadow: 0 0 20px rgba(255, 20, 147, 0.3);
  }

  .category-count {
    background: rgba(255, 255, 255, 0.15);
    padding: 2px 10px;
    border-radius: 15px;
    font-size: 0.8rem;
  }

  .category-btn.active .category-count {
    background: rgba(255, 105, 180, 0.4);
  }

  /* 文章组 */
  .posts-group {
    display: none;
  }

  .posts-group.active {
    display: block;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .group-title {
    font-size: 1.5rem;
    color: var(--primary);
    margin-bottom: 30px;
    padding-left: 15px;
    border-left: 3px solid var(--secondary);
  }

  .posts-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 100%;
    background: linear-gradient(180deg, rgba(255, 20, 147, 0.05) 0%, transparent 100%);
    border-radius: 0 0 50% 50%;
    pointer-events: none;
  }

  .gallery-section {
    padding: 120px 40px;
    max-width: 1400px;
    margin: 0 auto 80px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.08), rgba(168, 85, 247, 0.08));
    border: 1px solid rgba(255, 105, 180, 0.15);
    border-radius: 50px;
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
  }

  .gallery-section::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 105, 180, 0.1) 0%, transparent 50%);
    animation: rotate 30s linear infinite;
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .section-title {
    font-size: 3rem;
    text-align: center;
    margin-bottom: 15px;
    font-weight: 700;
    position: relative;
    background: linear-gradient(135deg, var(--text-light), var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 60px;
    font-weight: 300;
    letter-spacing: 2px;
  }

  .posts-grid, .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 35px;
    position: relative;
    z-index: 1;
  }

  .post-card {
    background: linear-gradient(145deg, rgba(30, 27, 46, 0.9), rgba(20, 15, 35, 0.95));
    border-radius: 30px;
    padding: 40px;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 105, 180, 0.15);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(15px);
  }

  .post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, var(--primary), var(--secondary), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .post-card:hover::before {
    opacity: 1;
  }

  .post-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 105, 180, 0.1), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .post-card:hover::after {
    opacity: 1;
  }

  .post-card:hover {
    transform: translateY(-15px) scale(1.02);
    border-color: rgba(255, 105, 180, 0.4);
    box-shadow: 
      0 30px 80px rgba(255, 20, 147, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.08) inset;
  }

  .post-date {
    font-size: 0.9rem;
    color: var(--secondary);
    margin-bottom: 18px;
    font-weight: 500;
    letter-spacing: 1px;
  }

  .post-title {
    font-size: 1.6rem;
    margin-bottom: 18px;
    color: var(--text-light);
    font-weight: 700;
    line-height: 1.4;
  }

  .post-excerpt {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.9;
  }

  .post-tags {
    display: flex;
    gap: 15px;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 8px 22px;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.2), rgba(255, 105, 180, 0.2));
    border: 1px solid rgba(255, 105, 180, 0.4);
    border-radius: 30px;
    font-size: 0.9rem;
    color: var(--accent);
    transition: all 0.4s ease;
    cursor: pointer;
  }

  .tag:hover {
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.35), rgba(255, 105, 180, 0.35));
    transform: scale(1.1) translateY(-2px);
    box-shadow: 0 5px 20px rgba(255, 20, 147, 0.3);
  }

  .gallery-item {
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    aspect-ratio: 3/4;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(255, 105, 180, 0.15);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.08);
  }
    justify-content: center;
    align-items: center;
    transition: transform 0.4s ease;
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px 25px;
    background: linear-gradient(transparent, rgba(13, 11, 20, 0.95) 40%);
    transform: translateY(60px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: center;
  }

  .gallery-item:hover .gallery-overlay {
    transform: translateY(0);
  }

  .gallery-overlay h4 {
    color: var(--accent);
    margin-bottom: 8px;
    font-size: 1.3rem;
    font-weight: 600;
    text-shadow: 0 2px 10px rgba(255, 20, 147, 0.5);
  }

  .gallery-overlay p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-light);
    border: 2px solid var(--secondary);
  }

  .btn-secondary:hover {
    background: var(--secondary);
  }

  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>